# Dominio principal de la aplicacion (usado por Caddy)
APP_DOMAIN=pruebas.coradir.ai

# URL del sitio para SEO y sitemap (produccion: https://homes.coradir.com.ar)
NEXT_PUBLIC_SITE_URL=https://homes.coradir.com.ar

# URL del webhook de N8N (actualizar con tu webhook real)
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# reCAPTCHA Enterprise credentials
# Site Key (obtener de Google reCAPTCHA Console)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Project ID de Google Cloud (ej: captcha-v3-463413)
RECAPTCHA_PROJECT_ID=

# API Key de Google Cloud (obtener de APIs & Services > Credentials)
# Debe tener habilitada la API "reCAPTCHA Enterprise API"
RECAPTCHA_API_KEY=

# Score minimo para validar reCAPTCHA (opcional, default: 0.5)
RECAPTCHA_MIN_SCORE=0.5

# URL del script del chatbot
NEXT_PUBLIC_BOT_SCRIPT_URL=https://testbothome.coradir.ai/embed.js

# Bot calificador nativo Homes
NEXT_PUBLIC_LEAD_BOT_ENABLED=false
NEXT_PUBLIC_LEAD_BOT_WHATSAPP_NUMBER=5492664649967

# Integracion server-to-server con CRM Homes del sistema inmobiliario
LEAD_BOT_INTEGRATION_PROVIDER=homes-crm
HOMES_CRM_BASE_URL=http://localhost:3076
HOMES_CRM_WEBHOOK_TOKEN=
N8N_LEAD_BOT_WEBHOOK_URL=

# Persistencia y resumen diario del bot (PostgreSQL + SMTP)
LEAD_BOT_DATABASE_URL=postgresql://usuario:password@host:5432/base
LEAD_BOT_DATABASE_SSL=false
LEAD_BOT_CRON_SECRET=
LEAD_BOT_REPORT_TO=homes@coradir.com.ar
LEAD_BOT_REPORT_FROM=web@coradir.com.ar
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Proveedor IA opcional para el bot nativo
# La key va siempre en LEAD_BOT_LLM_API_KEY. No usar NEXT_PUBLIC para keys privadas.
#
# xAI / Grok (OpenAI-compatible)
# LEAD_BOT_LLM_PROVIDER=openai-compatible
# LEAD_BOT_LLM_MODEL=grok-4-1-fast-non-reasoning
# LEAD_BOT_LLM_BASE_URL=https://api.x.ai/v1
# LEAD_BOT_LLM_API_KEY=xai-...
#
# OpenAI
# LEAD_BOT_LLM_PROVIDER=openai-compatible
# LEAD_BOT_LLM_MODEL=gpt-4o-mini
# LEAD_BOT_LLM_BASE_URL=https://api.openai.com/v1
# LEAD_BOT_LLM_API_KEY=sk-...
#
# DeepSeek
# LEAD_BOT_LLM_PROVIDER=openai-compatible
# LEAD_BOT_LLM_MODEL=deepseek-chat
# LEAD_BOT_LLM_BASE_URL=https://api.deepseek.com
# LEAD_BOT_LLM_API_KEY=sk-...
#
# Z.ai / GLM (coding plan). DISABLE_THINKING es clave: sin eso los GLM razonan y tardan mas de 20s.
# LEAD_BOT_LLM_PROVIDER=openai-compatible
# LEAD_BOT_LLM_MODEL=glm-5-turbo
# LEAD_BOT_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# LEAD_BOT_LLM_API_KEY=...
# LEAD_BOT_LLM_DISABLE_THINKING=true
#
# Gemini
# LEAD_BOT_LLM_PROVIDER=gemini
# LEAD_BOT_LLM_MODEL=gemini-2.5-flash
# LEAD_BOT_LLM_BASE_URL=
# LEAD_BOT_LLM_API_KEY=...
#
# Ollama local
# LEAD_BOT_LLM_PROVIDER=ollama
# LEAD_BOT_LLM_MODEL=llama3.1
# LEAD_BOT_LLM_BASE_URL=http://localhost:11434
# LEAD_BOT_LLM_API_KEY=
LEAD_BOT_LLM_PROVIDER=openai-compatible
LEAD_BOT_LLM_MODEL=
LEAD_BOT_LLM_BASE_URL=
LEAD_BOT_LLM_API_KEY=
LEAD_BOT_LLM_TIMEOUT_MS=4500
LEAD_BOT_LLM_DISABLE_THINKING=false
